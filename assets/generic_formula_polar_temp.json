{
  "name": "Polar Temperature",
  "type": "formula_collection",
  "formulas": {
    "tilt_more_5": {
      "formula": "P = T - (7*S)",
      "notes": "Axial tilt > 5 degrees. P = Polar Temp in Celsius, S = Size Code, T = Avg Temp in Celsius"
    },
    "tilt_less_5_summer": {
      "formula": "P = [M * (A * 0.6)] + (7*S) + T",
      "notes": "Axial tilt < 5 degrees, summer"
    },
    "tilt_less_5_winter": {
      "formula": "P = [T + (7*S)] - [M * (A * 0.6)]",
      "notes": "Axial tilt < 5 degrees, winter"
    }
  }
}
